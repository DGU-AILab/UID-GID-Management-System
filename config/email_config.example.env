# Copy this file to email_config.local.env and fill in real values.

# SMTP relay settings
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Sender identity
SMTP_FROM=svmanager@example.com
SMTP_FROM_NAME=DGU AILab Server Manager
SMTP_REPLY_TO=svmanager@example.com

# Optional SMTP auth
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TIMEOUT=30

# Optional: override all recipients during testing
# EMAIL_TO_OVERRIDE=your-email@example.com

# Optional: links referenced in reminder emails
SUPPORT_MANUAL_URL=https://example.com/manual
ERROR_REPORT_FORM_URL=https://example.com/error-report-form
