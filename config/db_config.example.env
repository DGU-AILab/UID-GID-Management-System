# Copy this file to db_config.local.env and fill in real values.

# Shared database settings
DB_PORT=3307
DB_NAME=nfs_db
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_CHARSET=utf8mb4

# Domain-specific database hosts
LAB_DB_HOST=192.168.1.11
FARM_DB_HOST=192.168.2.11

# Optional fallback for scripts that still use a single DB host
DB_HOST=127.0.0.1

# Ansible inventory used by create/delete from the management server
ANSIBLE_INVENTORY=/home/jy/ansible/inventory.ini

# Optional local backup root created by create/delete on the management server
BACKUP_ROOT_DIR=/path/to/mysql_backups

# LAB-only storage provisioning for NFS root_squash environments.
# LAB_STORAGE_USER_SHARE_ROOT is the path on the storage server.
# LAB_HOST_USER_SHARE_ROOT_TEMPLATE is the NFS mount path on each LAB Docker host.
LAB_STORAGE_HOST=192.168.1.20
LAB_STORAGE_PORT=6953
LAB_STORAGE_USER=jy
# LAB_STORAGE_SSH_KEY=/home/jy/.ssh/id_ed25519
# LAB_STORAGE_SSH_COMMON_ARGS="-o ProxyJump=jy@192.168.1.12:8082"
LAB_STORAGE_USER_SHARE_ROOT=/294t/dcloud/share/user-share
LAB_STORAGE_SUDO="sudo -n"
LAB_HOST_USER_SHARE_ROOT_TEMPLATE=/home/tako{server_number}/share/user-share

# FARM-only NAS provisioning for NFS root_squash environments
FARM_NAS_HOST=192.168.2.30
FARM_NAS_PORT=6954
FARM_NAS_USER=jy
# FARM_NAS_SSH_KEY=/home/jy/.ssh/id_ed25519
FARM_NAS_USER_SHARE_ROOT=/volume1/share/user-share
FARM_NAS_SUDO="sudo -n"

# FARM-only Kerberized NFS container mode.
# Kerberos containers can be created on any FARM host listed here. The target
# host must be an AD DC because keytabs and host ccaches are managed locally.
FARM_KERBEROS_AD_NETBIOS=FARM
FARM_KERBEROS_REALM=FARM.DECS.INTERNAL
FARM_KERBEROS_NIS_DOMAIN=farm
FARM_KERBEROS_AD_DC_HOSTS=farm2,farm6,farm7
# Backward-compatible fallback used only when FARM_KERBEROS_AD_DC_HOSTS is unset.
FARM_KERBEROS_AD_DC_HOST=farm2
FARM_KERBEROS_NAS_USER_SHARE_ROOT=/volume1/test_krb/user-share
FARM_KERBEROS_NAS_RESTART_GSS_SERVICES=true
FARM_KERBEROS_NAS_SVCGSSD=/usr/sbin/svcgssd
FARM_KERBEROS_NAS_IDMAPD=/usr/sbin/idmapd
FARM_KERBEROS_NAS_NFS_PRINCIPAL=nfs/nas.farm.decs.internal@FARM.DECS.INTERNAL
FARM_KERBEROS_MOUNT_USER_SHARE_ROOT=/mnt/nas-krb-test-v4/user-share
FARM_KERBEROS_CCACHE_BASE=/run/user
FARM_KERBEROS_KRB5_CONF=/etc/krb5.conf
FARM_KERBEROS_KEYTAB_DIR=/etc/decs-krb/keytabs
FARM_KERBEROS_REFRESH_ENV_DIR=/etc/decs-krb/refresh.d
FARM_KERBEROS_REFRESH_INTERVAL=1h
FARM_KERBEROS_NAS_IDENTITY_RETRIES=12
FARM_KERBEROS_NAS_IDENTITY_RETRY_DELAY=5
FARM_KERBEROS_NFS_ACCESS_INITIAL_DELAY=30
FARM_KERBEROS_NFS_ACCESS_RETRIES=12
FARM_KERBEROS_NFS_ACCESS_RETRY_DELAY=5
KERBEROS_REMOTE_SUDO="sudo -n"

# Default domains for export script
EXPORT_DOMAINS=LAB,FARM
SERVER_DOMAIN=LAB
