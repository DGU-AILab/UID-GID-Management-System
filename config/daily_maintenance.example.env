# Copy this file to daily_maintenance.local.env and adjust values for the management server.

# systemd OnCalendar expression. Default is every day at 11:00 Korea time.
DAILY_MAINTENANCE_ON_CALENDAR="*-*-* 11:00:00 Asia/Seoul"

# Log file written by uid-gid-daily-maintenance.service
DAILY_MAINTENANCE_LOG_FILE=/var/log/uid-gid-daily-maintenance.log

# Because logrotate runs daily, this also acts as "days to keep".
DAILY_MAINTENANCE_LOG_ROTATE_COUNT=14

# Domains passed to run_daily_maintenance.sh. Comma-separated.
DAILY_MAINTENANCE_DOMAINS=LAB,FARM
